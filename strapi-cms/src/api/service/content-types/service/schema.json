{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "icon": {
      "type": "customField",
      "customField": "plugin::strapi-lucide-icons.icon"
    },
    "excerpt": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "features": {
      "type": "component",
      "component": "shared.feature",
      "repeatable": true
    },
    "packages": {
      "type": "component",
      "component": "shared.package",
      "repeatable": true,
      "max": 3
    }
  }
}
